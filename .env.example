# ===========================================
# 🤖 ROV AI Analyzer - Configuration
# ===========================================
# Copy this file to .env and fill in your values

# ===========================================
# REQUIRED - AI & Telegram Setup
# ===========================================

# Get free API key at https://openrouter.ai/
OPENROUTER_API_KEY=your-openrouter-api-key-here

# Get bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=your-telegram-bot-token

# Get your chat ID from https://t.me/userinfobot
TELEGRAM_CHAT_ID=your-telegram-chat-id

# ===========================================
# 📁 Folders - Adjust to your system
# ===========================================
# Windows example: D:\ROV_Videos
# Linux example: /home/user/ROV_Videos

# Where the tool watches for new videos
WATCH_FOLDER=D:\ROV_Videos

# Where processed jobs are saved (frames + metadata)
OUTPUT_FOLDER=D:\ROV_Jobs

# Where PDF reports are saved
REPORTS_FOLDER=D:\ROV_Reports

# ===========================================
# 🤖 AI Model Settings
# ===========================================
# Recommended: google/gemini-2.5-flash-lite (fast & cheap)
# Alternative: anthropic/claude-3-haiku
MODEL_ID=google/gemini-2.5-flash-lite

# OpenRouter API endpoint (usually don't change)
OR_API_URL=https://openrouter.ai/api/v1/chat/completions

# ===========================================
# ⚙️ Advanced Options
# ===========================================
# Extract one frame every X seconds (lower = more frames = slower)
FRAME_EVERY_SEC=5

# Test mode: only process 5 frames (set to "true" for testing)
VERIFICATION_MODE=false

# How long to wait for Telegram approval (in seconds)
APPROVAL_TIMEOUT_SEC=600
